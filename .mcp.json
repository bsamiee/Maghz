{
  "mcpServers": {
    "postgres": {
      "command": "uvx",
      "args": [
        "--python",
        "3.13",
        "postgres-mcp",
        "--access-mode=restricted"
      ],
      "env": {
        "DATABASE_URI": "${MAGHZ_MCP__DATABASE_URI}",
        "UV_PYTHON_DOWNLOADS": "automatic"
      }
    },
    "n8n": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--init",
        "-e",
        "MCP_MODE=stdio",
        "-e",
        "LOG_LEVEL=error",
        "-e",
        "DISABLE_CONSOLE_OUTPUT=true",
        "-e",
        "N8N_API_URL=${MAGHZ_MCP__N8N_API_URL}",
        "-e",
        "N8N_API_KEY=${MAGHZ_MCP__N8N_API_KEY}",
        "ghcr.io/czlonkowski/n8n-mcp:latest"
      ],
      "env": {}
    },
    "workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tool-tier",
        "extended"
      ],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}",
        "WORKSPACE_MCP_CREDENTIALS_DIR": ".cache/workspace-mcp"
      }
    },
    "notebooklm": {
      "command": "notebooklm-mcp",
      "args": [],
      "env": {}
    },
    "exa": {
      "command": "npx",
      "args": [
        "-y",
        "exa-mcp-server"
      ],
      "env": {
        "EXA_API_KEY": "${EXA_API_KEY}"
      }
    },
    "perplexity": {
      "command": "npx",
      "args": [
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp@latest"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "hostinger": {
      "command": "npx",
      "args": [
        "-y",
        "hostinger-api-mcp"
      ],
      "env": {
        "HOSTINGER_API_TOKEN": "${HOSTINGER_TOKEN}"
      }
    }
  }
}