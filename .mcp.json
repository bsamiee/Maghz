{
  "mcpServers": {
    "postgres": {
      "command": "uvx",
      "args": [
        "postgres-mcp",
        "--access-mode=restricted"
      ],
      "env": {
        "DATABASE_URI": "${MAGHZ_MCP__DATABASE_URI}"
      }
    },
    "n8n": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--init",
        "-e",
        "MCP_MODE=stdio",
        "-e",
        "LOG_LEVEL=error",
        "-e",
        "DISABLE_CONSOLE_OUTPUT=true",
        "-e",
        "N8N_API_URL=${MAGHZ_MCP__N8N_API_URL}",
        "-e",
        "N8N_API_KEY=${MAGHZ_MCP__N8N_API_KEY}",
        "ghcr.io/czlonkowski/n8n-mcp:latest"
      ],
      "env": {}
    },
    "workspace": {
      "command": "uvx",
      "args": [
        "workspace-mcp",
        "--tool-tier",
        "extended"
      ],
      "env": {
        "GOOGLE_OAUTH_CLIENT_ID": "${GOOGLE_OAUTH_CLIENT_ID}",
        "GOOGLE_OAUTH_CLIENT_SECRET": "${GOOGLE_OAUTH_CLIENT_SECRET}",
        "WORKSPACE_MCP_CREDENTIALS_DIR": ".cache/workspace-mcp"
      }
    },
    "notebooklm": {
      "command": "notebooklm-mcp",
      "args": [],
      "env": {}
    }
  }
}