root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_style = space
indent_size = 4
max_line_length = 150

[*.{ts,tsx,js,jsx,mts,cts}]
indent_style = space
indent_size = 4
max_line_length = 150

[*.{yml,yaml}]
indent_style = space
indent_size = 4
max_line_length = 150

[*.{sh,bash}]
switch_case_indent = true
